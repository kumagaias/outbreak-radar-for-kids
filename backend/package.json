{
  "name": "nova-recommendations-backend",
  "version": "1.0.0",
  "description": "Lambda function for Nova AI Recommendations",
  "main": "index.js",
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=__tests__ --testPathIgnorePatterns=properties",
    "test:pbt": "jest --testPathPattern=properties",
    "test:pbt:critical": "jest __tests__/properties/critical.properties.test.js",
    "test:pbt:standard": "jest __tests__/properties/standard.properties.test.js",
    "test:pbt:extended": "jest __tests__/properties/extended.properties.test.js"
  },
  "keywords": [
    "lambda",
    "bedrock",
    "nova"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.0.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-ssm": "^3.1008.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "iconv-lite": "^0.7.2"
  },
  "devDependencies": {
    "@aws-sdk/client-lambda": "^3.1008.0",
    "fast-check": "^4.6.0",
    "jest": "^29.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "lib/**/*.js",
      "index.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    },
    "maxWorkers": "50%",
    "workerIdleMemoryLimit": "512MB",
    "clearMocks": true,
    "resetMocks": true,
    "restoreMocks": true
  }
}
